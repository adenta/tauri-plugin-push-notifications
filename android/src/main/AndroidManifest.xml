<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.tauri.pushnotifications"> <!-- Must match the namespace in build.gradle.kts -->

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required for FCM on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application>
        <!-- FCM Service Declaration -->
        <service
            android:name=".FCMService" <!-- Use relative path from package -->
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Optional: Metadata for default notification icon and color -->
        <!-- These will be used if the incoming message doesn't specify them -->
        <!--
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
        -->
         <!-- Optional: Default channel ID for FCM messages without a channel specified -->
        <!--
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/default_notification_channel_id"/>
        -->
    </application>
</manifest>
